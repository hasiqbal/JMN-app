# Supabase Configuration
# Get these values from your Supabase project dashboard
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# Optional legacy fallback during migration only
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your-legacy-anon-key-here

# Quran page source (recommended for production)
# Option 1: Single CDN base with per-layout folders (expects /15line and /16line)
# EXPO_PUBLIC_QURAN_PAGES_CDN_BASE_URL=https://cdn.example.com/quran-pages

# Option 2: Explicit per-layout bases
# EXPO_PUBLIC_QURAN_15LINE_BASE_URL=https://cdn.example.com/quran-pages/15line
# EXPO_PUBLIC_QURAN_16LINE_BASE_URL=https://cdn.example.com/quran-pages/16line

# Optional Supabase Storage tuning when using EXPO_PUBLIC_SUPABASE_URL fallback
# EXPO_PUBLIC_QURAN_STORAGE_BUCKET=quran-pages
# EXPO_PUBLIC_QURAN_15LINE_STORAGE_PREFIX=15line
# EXPO_PUBLIC_QURAN_16LINE_STORAGE_PREFIX=16line

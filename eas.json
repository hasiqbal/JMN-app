{
  "cli": {
    "version": ">= 18.7.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "22.22.2",
      "pnpm": "10.14.0",
      "cache": {
        "paths": [
          "/home/expo/.gradle/caches",
          "/home/expo/.gradle/wrapper"
        ]
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      }
    },
    "preview": {
      "distribution": "internal",
      "node": "22.22.2",
      "pnpm": "10.14.0",
      "cache": {
        "paths": [
          "/home/expo/.gradle/caches",
          "/home/expo/.gradle/wrapper"
        ]
      }
    },
    "production": {
      "autoIncrement": true,
      "node": "22.22.2",
      "pnpm": "10.14.0",
      "android": {
        "buildType": "app-bundle"
      },
      "cache": {
        "paths": [
          "/home/expo/.gradle/caches",
          "/home/expo/.gradle/wrapper",
          "/Users/expo/Library/Caches/CocoaPods"
        ]
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "internal",
        "releaseStatus": "draft"
      }
    }
  }
}
